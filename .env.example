# Required Database and API credentials
MONGODB_URI=mongodb+srv://your-mongodb-uri
DB_NAME=jorbites
GEMINI_API_KEY=your-gemini-api-key
TURSO_URL=libsql://your-db-org.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Processing & Pace Configuration
SLEEP_BETWEEN_RECIPES_SECS=60   # 1 RPM (slow/robust tier pace)
IDLE_SLEEP_SECS=600              # 10 minutes wait when all recipes are audited
MAX_RETRIES=3                    # Number of retries on errors before giving up
RETRY_COOLDOWN_HOURS=24          # Wait period before retrying a failed recipe

# Optional — SMTP email alerts for recipe failures after max retries
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=your-smtp-password
ALERT_EMAIL_FROM="Tagatoni Agent <alerts@example.com>"
ALERT_EMAIL_TO=admin@example.com
